# Redis connection
REDIS_URL=redis://localhost:6379/0

# Worker configuration
CHRONOQ_WORKER_COUNT=4

# Queue keys
CHRONOQ_QUEUE_KEY=chronoq:tasks
CHRONOQ_TASK_PREFIX=chronoq:task:

# Predictor storage
CHRONOQ_PREDICTOR_STORAGE=sqlite:///chronoq_telemetry.db

# ML model thresholds
CHRONOQ_COLD_START=50
CHRONOQ_RETRAIN_EVERY=100
